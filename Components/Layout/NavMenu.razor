@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization

@inject Progetto_Web_2_IoT_Auth.Services.ThemeService Theme
@implements IDisposable

<AuthorizeView>
    <Authorized>
        <MudPaper Class="d-flex flex-row align-items-center p-2" Elevation="1">
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Dashboard" Class="mx-2">Dashboard</MudNavLink>
            <MudNavLink Href="/devices" Icon="@Icons.Material.Filled.Devices" Class="mx-2">Devices</MudNavLink>
            <MudNavLink Href="/automations" Icon="@Icons.Material.Filled.Alarm" Class="mx-2">Automations</MudNavLink>
            

            <AuthorizeView Roles="admin" Context="adminContext">
                <Authorized>
                    <MudNavLink Href="/manage-users" Icon="@Icons.Material.Filled.PeopleAlt" Class="mx-2">Manage Users</MudNavLink>
                    <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings" Class="mx-2">Settings</MudNavLink>
                </Authorized>
            </AuthorizeView>

            <MudSpacer />
            <MudNavLink Href="/logout" Icon="@Icons.Material.Filled.ExitToApp" Class="mx-2">Logout</MudNavLink>

            <MudToggleIconButton Toggled="@Theme.IsDarkMode"
                                 ToggledChanged="SetThemeAsync"
                                 Icon="@Icons.Material.Filled.DarkMode"
                                 ToggledIcon="@Icons.Material.Filled.LightMode"
                                 Color="Color.Default"
                                 Class="mx-2" />
        </MudPaper>
    </Authorized>
</AuthorizeView>

@code {
    protected override void OnInitialized()
    {
        Theme.OnChange += OnThemeChanged;
    }

    private Task SetThemeAsync(bool value) => Theme.SetDarkModeAsync(value);

    private void OnThemeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Theme.OnChange -= OnThemeChanged;
    }
}

