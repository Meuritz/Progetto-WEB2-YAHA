@page "/manage-users"
@using Microsoft.EntityFrameworkCore
@using Progetto_Web_2_IoT_Auth.Data.Model
@inject DbContextSQLite Db
@inject NavigationManager Nav
@using MudBlazor

<MudPaper Class="pa-6 mt-6">
    <MudStack Row="true" JustifyContent="space-between" Class="mb-4">
        <MudText Typo="Typo.h5">Utenti Registrati</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="GoToRegister">
            Aggiungi Utente
        </MudButton>
    </MudStack>

    <MudTable Items="_users" Dense="true" Hover="true" Bordered="true" Striped="true">
        <HeaderContent>
            <MudTh>Nome</MudTh>
            <MudTh>Ruolo</MudTh>
            <MudTh>Gestione</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Nome">@context.Name</MudTd>
            <MudTd DataLabel="Ruolo">@context.Role</MudTd>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete">
                Elimina
            </MudButton>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {
    private List<User> _users = new();

    protected override async Task OnInitializedAsync()
    {
        _users = await Db.User.OrderBy(u => u.Name).ToListAsync();
    }   

    private void GoToRegister()
    {
        Nav.NavigateTo("/register");
    }
}
