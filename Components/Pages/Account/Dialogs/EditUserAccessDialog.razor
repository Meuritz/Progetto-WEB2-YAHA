@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Progetto_Web_2_IoT_Auth.Data
@using Progetto_Web_2_IoT_Auth.Data.Model

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">Gestisci accessi</MudText>

            <MudText Typo="Typo.body2">Utente: <b>@Username</b></MudText>

            <MudTable Items="_rows" Dense="true" Hover="true" Bordered="true" Striped="true">
                <HeaderContent>
                    <MudTh>Zona</MudTh>
                    <MudTh>Access Level</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Zona">@context.ZoneName</MudTd>
                    <MudTd DataLabel="Access Level">
                        <MudSelect T="string" @bind-Value="context.AccessLevel" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">(nessuno)</MudSelectItem>
                            <MudSelectItem Value="@("view")">view</MudSelectItem>
                            <MudSelectItem Value="@("operator")">operator</MudSelectItem>
                        </MudSelect>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Annulla</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">Salva</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public int UserId { get; set; }
    [Parameter] public string Username { get; set; } = string.Empty;

    [Inject] private DbContextSQLite Db { get; set; } = null!;

    private readonly List<ZoneAccessRow> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        var userRole = await Db.Users
            .AsNoTracking()
            .Where(u => u.Id == UserId)
            .Select(u => u.Role)
            .FirstOrDefaultAsync();

        if (string.Equals(userRole?.Trim(), "admin", StringComparison.OrdinalIgnoreCase))
        {
            MudDialog.Close(DialogResult.Ok(false));
            return;
        }

        var zones = await Db.Zones
            .AsNoTracking()
            .OrderBy(z => z.Name)
            .ToListAsync();

        var accesses = await Db.Accesses
            .AsNoTracking()
            .Where(a => a.UserId == UserId)
            .ToListAsync();

        _rows.Clear();
        foreach (var zone in zones)
        {
            var access = accesses.FirstOrDefault(a => a.ZoneId == zone.Id);
            _rows.Add(new ZoneAccessRow
            {
                ZoneId = zone.Id,
                ZoneName = zone.Name,
                AccessLevel = access?.AccessLevel ?? string.Empty
            });
        }
    }

    private async Task SaveAsync()
    {
        var userRole = await Db.Users
            .AsNoTracking()
            .Where(u => u.Id == UserId)
            .Select(u => u.Role)
            .FirstOrDefaultAsync();

        if (string.Equals(userRole?.Trim(), "admin", StringComparison.OrdinalIgnoreCase))
        {
            MudDialog.Close(DialogResult.Ok(false));
            return;
        }

        var existingAccesses = await Db.Accesses
            .Where(a => a.UserId == UserId)
            .ToListAsync();

        foreach (var row in _rows)
        {
            var desired = (row.AccessLevel ?? string.Empty).Trim().ToLowerInvariant();
            var existing = existingAccesses.FirstOrDefault(a => a.ZoneId == row.ZoneId);

            if (string.IsNullOrWhiteSpace(desired))
            {
                if (existing is not null)
                    Db.Accesses.Remove(existing);

                continue;
            }

            if (desired is not ("view" or "operator"))
                continue;

            if (existing is null)
            {
                Db.Accesses.Add(new Access
                {
                    UserId = UserId,
                    ZoneId = row.ZoneId,
                    AccessLevel = desired
                });
            }
            else
            {
                existing.AccessLevel = desired;
            }
        }

        await Db.SaveChangesAsync();
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();

    private sealed class ZoneAccessRow
    {
        public int ZoneId { get; set; }
        public string ZoneName { get; set; } = string.Empty;
        public string AccessLevel { get; set; } = string.Empty;
    }
}
