@page "/login"
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Progetto_Web_2_IoT_Auth.Data
@using Progetto_Web_2_IoT_Auth.Data.Model.WievModels
@using System.Security.Claims
@inject DbContextSQLite DbContextSQLite
@inject HttpClient Http
@inject NavigationManager NavigationManager

<MudPaper Class="pa-6 mx-auto mt-20" MaxWidth="30em" Elevation="4">
    <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">Login</MudText>

    <MudForm @ref="form" Model="Model" OnValidSubmit="AuthenticateAsync">
        <MudTextField @bind-Value="Model.Username"
                      Label="Username"
                      For="@(() => Model.Username)"
                      Required="true"
                      RequiredError="L'username è obbligatorio"
                      Class="mb-3"
                      InputType="InputType.Text" />

        <MudTextField @bind-Value="Model.Password"
                      Label="Password"
                      For="@(() => Model.Password)"
                      Required="true"
                      RequiredError="La password è obbligatoria"
                      Class="mb-3"
                      InputType="InputType.Password" />

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">@errorMessage</MudAlert>
        }

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">
            Accedi
        </MudButton>
    </MudForm>
</MudPaper>

@code {
    [SupplyParameterFromForm]
    public LoginViewModel Model { get; set; } = new();

    private MudForm? form;
    private string? errorMessage;

    private async Task AuthenticateAsync()
    {
        errorMessage = null;
        var response = await Http.PostAsJsonAsync("api/auth/login", Model);

        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo("/", true); // true forza il reload
        }
        else
        {
            errorMessage = "Credenziali non valide. Riprova.";
        }
    }
}