@page "/automations"
@using Microsoft.EntityFrameworkCore
@using Progetto_Web_2_IoT_Auth.Data.Model
@using Progetto_Web_2_IoT_Auth.Components.Pages.Automations.Dialogs
@using Progetto_Web_2_IoT_Auth.Services
@inject DbContextSQLite Db
@inject UserAccessService AccessService
@inject ISnackbar Snackbar
@inject IDialogService Dialog

@attribute [Authorize]

<PageTitle>Automations</PageTitle>

<MudPaper Class="pa-6 mt-6">
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h5">Automations</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary" OnClick="ReloadAsync" Disabled="_loading" />
            @if (_access?.CanOperateAny == true)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialogAsync" Disabled="_loading">
                    Add automation
                </MudButton>
            }
        </MudStack>

        <MudDivider />

        @if (_loading)
        {
            <MudStack Class="pa-6" AlignItems="AlignItems.Center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </MudStack>
        }
        else if (_automations.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                No automations configured.
            </MudAlert>
        }
        else
        {
            <MudTable Items="_automations" Dense="true" Hover="true" Bordered="true" Striped="true">
                <HeaderContent>
                    <MudTh>Device</MudTh>
                    <MudTh>Zone</MudTh>
                    <MudTh>Power</MudTh>
                    <MudTh>Level</MudTh>
                    <MudTh>Schedule</MudTh>
                    <MudTh>Weather</MudTh>
                    @if (_access?.CanOperateAny == true)
                    {
                        <MudTh></MudTh>
                    }
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Device">@context.DeviceName</MudTd>
                    <MudTd DataLabel="Zone">@context.ZoneName</MudTd>
                    <MudTd DataLabel="Power">
                        <MudIcon Icon="@(context.Power ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                 Color="@(context.Power ? Color.Success : Color.Default)" />
                    </MudTd>
                    <MudTd DataLabel="Level">@context.Level</MudTd>
                    <MudTd DataLabel="Schedule">
                        @if (string.IsNullOrWhiteSpace(context.TimeCondition))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Default">Always</MudText>
                        }
                        else
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
                                <MudText Typo="Typo.body2">@context.TimeCondition</MudText>
                            </MudStack>
                        }
                    </MudTd>
                    <MudTd DataLabel="Weather">
                        @switch (context.WeatherCondition)
                        {
                            case "rain":
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Icon="@Icons.Material.Filled.WaterDrop">Rain</MudChip>
                                break;
                            case "no_rain":
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.WbSunny">No rain</MudChip>
                                break;
                            default:
                                <MudText Typo="Typo.body2" Color="Color.Default">Any</MudText>
                                break;
                        }
                    </MudTd>
                    @if (_access?.CanOperateAny == true)
                    {
                        <MudTd>
                            @if (context.CanOperate)
                            {
                                <MudStack Row="true" Spacing="0">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                                   OnClick="@(() => OpenEditDialogAsync(context))" Disabled="_loading" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => DeleteAsync(context))" Disabled="_loading" />
                                </MudStack>
                            }
                        </MudTd>
                    }
                </RowTemplate>
            </MudTable>
        }
    </MudStack>
</MudPaper>

@code {
    private bool _loading;
    private UserAccessInfo _access = null!;

    private readonly SemaphoreSlim _dbLock = new(1, 1);
    private readonly List<AutomationRow> _automations = new();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        await _dbLock.WaitAsync();
        try
        {
            _access = await AccessService.GetAccessInfoAsync();

            _automations.Clear();

            List<int> deviceIds;

            if (_access.IsAdmin)
            {
                deviceIds = await Db.Devices.AsNoTracking().Select(d => d.Id).ToListAsync();
            }
            else
            {
                var zoneIds = _access.AccessibleZoneIds;
                deviceIds = zoneIds.Count > 0
                    ? await Db.Devices.AsNoTracking()
                        .Where(d => zoneIds.Contains(d.ZoneId))
                        .Select(d => d.Id)
                        .ToListAsync()
                    : new List<int>();
            }

            if (deviceIds.Count > 0)
            {
                var automations = await Db.Automations
                    .AsNoTracking()
                    .Include(a => a.Device)
                        .ThenInclude(d => d.Zone)
                    .Where(a => deviceIds.Contains(a.DeviceId))
                    .OrderBy(a => a.Device.Zone.Name)
                    .ThenBy(a => a.Device.Name)
                    .ToListAsync();

                foreach (var a in automations)
                {
                    _automations.Add(new AutomationRow
                    {
                        Id = a.Id,
                        ZoneId = a.Device?.ZoneId ?? 0,
                        DeviceName = a.Device?.Name ?? string.Empty,
                        ZoneName = a.Device?.Zone?.Name ?? string.Empty,
                        Power = a.Power,
                        Level = a.Level,
                        TimeCondition = a.TimeCondition,
                        WeatherCondition = a.WeatherCondition,
                        CanOperate = _access.CanOperateZone(a.Device?.ZoneId ?? 0)
                    });
                }
            }
        }
        finally
        {
            _dbLock.Release();
            _loading = false;
        }
    }

    private async Task OpenAddDialogAsync()
    {
        if (!_access.CanOperateAny)
            return;

        var dialog = await Dialog.ShowAsync<AddAutomationDialog>("Add automation",
            new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;
        if (result is null || result.Canceled)
            return;

        await ReloadAsync();
    }

    private async Task OpenEditDialogAsync(AutomationRow row)
    {
        if (!row.CanOperate)
            return;

        var parameters = new DialogParameters
        {
            [nameof(EditAutomationDialog.AutomationId)] = row.Id
        };

        var dialog = await Dialog.ShowAsync<EditAutomationDialog>("Edit automation", parameters,
            new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;
        if (result is null || result.Canceled)
            return;

        await ReloadAsync();
    }

    private async Task DeleteAsync(AutomationRow row)
    {
        if (!row.CanOperate)
            return;

        await _dbLock.WaitAsync();
        try
        {
            var affected = await Db.Automations
                .Where(a => a.Id == row.Id)
                .ExecuteDeleteAsync();

            if (affected == 1)
            {
                _automations.Remove(row);
                Snackbar.Add("Automation deleted.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Delete failed.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Error deleting automation.", Severity.Error);
        }
        finally
        {
            _dbLock.Release();
        }
    }

    private sealed class AutomationRow
    {
        public int Id { get; set; }
        public int ZoneId { get; set; }
        public string DeviceName { get; set; } = string.Empty;
        public string ZoneName { get; set; } = string.Empty;
        public bool Power { get; set; }
        public int Level { get; set; }
        public string TimeCondition { get; set; } = string.Empty;
        public string WeatherCondition { get; set; } = string.Empty;
        public bool CanOperate { get; set; }
    }
}
