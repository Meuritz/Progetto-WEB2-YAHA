@page "/devices"
@using Microsoft.EntityFrameworkCore
@using Progetto_Web_2_IoT_Auth.Data.Model
@using Progetto_Web_2_IoT_Auth.Components.Pages.Devices.Dialogs
@using Progetto_Web_2_IoT_Auth.Services
@inject DbContextSQLite Db
@inject UserAccessService AccessService
@inject ISnackbar Snackbar
@inject IDialogService Dialog

@attribute [Authorize]

<PageTitle>Devices</PageTitle>

<MudPaper Class="pa-6 mt-6">
        <MudStack Spacing="2">
            <MudStack Row="true" justifycontent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h5">Devices</MudText>
                <MudStack Row="true" Spacing="1">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary" OnClick="ReloadAsync" Disabled="_loading" />
                    @if (_isAdmin || _access.CanOperateAny)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDeviceDialogAsync" Disabled="_loading">
                            Add device
                        </MudButton>
                    }
                </MudStack>
        </MudStack>

        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="3">
                <MudTextField @bind-Value="_search"
                              Placeholder="Search by name, type or zone..."
                              Variant="Variant.Outlined"
                              Immediate="true"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudSelect T="int?" Label="Zone" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="_selectedZoneId" Style="flex:1">
                        <MudSelectItem T="int?" Value="@((int?)null)">(all)</MudSelectItem>
                        @foreach (var z in _zones)
                        {
                            <MudSelectItem T="int?" Value="@((int?)z.Id)">@z.Name</MudSelectItem>
                        }
                    </MudSelect>
                    
                    @if (_isAdmin)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Disabled="_loading" OnClick="OpenAddZoneDialogAsync" />
                        <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" Disabled="_loading" OnClick="OpenManageZonesDialogAsync" />
                    }
                </MudStack>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" Label="Device type" Variant="Variant.Outlined" Margin="Margin.Dense" MultiSelection="true" SelectedValues="_selectedTypes" SelectedValuesChanged="OnSelectedTypesChanged">
                    @foreach (var t in _deviceTypes)
                    {
                        <MudSelectItem Value="@t">@t</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" Label="Power" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="_powerFilter">
                    <MudSelectItem Value="@PowerFilterAll">all</MudSelectItem>
                    <MudSelectItem Value="@PowerFilterOn">on</MudSelectItem>
                    <MudSelectItem Value="@PowerFilterOff">off</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudStack>

    <MudDivider Class="my-4" />

    @if (_loading)
    {
        <MudStack Class="pa-6" AlignItems="AlignItems.Center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </MudStack>
    }
    else if (_zones.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            You don't have access to any zone (or no zones are configured).
        </MudAlert>
    }
    else
    {
        <MudTable Items="FilteredDevices" Dense="true" Hover="true" Bordered="true" Striped="true">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Zone</MudTh>
                <MudTh>IP</MudTh>
                <MudTh>Power</MudTh>
                <MudTh align="Align.Right">Level</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Type">@context.Type</MudTd>
                <MudTd DataLabel="Zone">
                    @if (_isAdmin)
                    {
                        <MudSelect T="int" Value="@context.ZoneId" ValueChanged="@((int v) => ChangeDeviceZoneAsync(context, v))" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                            @foreach (var z in _zones)
                            {
                                <MudSelectItem T="int" Value="@z.Id">@z.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        @context.ZoneName
                    }
                </MudTd>
                <MudTd DataLabel="IP">@context.IpAddress</MudTd>
                <MudTd DataLabel="Power">
                    @if (context.CanOperate)
                    {
                        <MudIconButton Icon="@(context.Power ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                       Color="@(context.Power ? Color.Success : Color.Default)"
                                       Disabled="_loading"
                                       OnClick="@(() => TogglePowerAsync(context, !context.Power))" />
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">@(context.Power ? "on" : "off")</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Level" align="Align.Right">
                    @if (context.CanOperate)
                    {
                        <MudStack Spacing="0">
                            <MudSlider T="int" Value="@context.Level" ValueChanged="@((int v) => UpdateLevelAsync(context, v))" Min="0" Max="100" Step="1" />
                            <MudText Typo="Typo.caption" Align="Align.Right">@context.Level</MudText>
                        </MudStack>
                    }
                    else
                    {
                        @context.Level
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private const string PowerFilterAll = "all";
    private const string PowerFilterOn = "on";
    private const string PowerFilterOff = "off";

    private bool _loading;

    private readonly SemaphoreSlim _dbLock = new(1, 1);

    private readonly List<Zone> _zones = new();
    private readonly List<DeviceRow> _devices = new();
    private readonly List<string> _deviceTypes = new();

    private string _search = string.Empty;
    private int? _selectedZoneId;
    private string _powerFilter = PowerFilterAll;
    private HashSet<string> _selectedTypes = new(StringComparer.OrdinalIgnoreCase);

    private bool _isAdmin;
    private UserAccessInfo _access = null!;

    private IEnumerable<DeviceRow> FilteredDevices
    {
        get
        {
            IEnumerable<DeviceRow> query = _devices;

            if (_selectedZoneId is int zid)
                query = query.Where(d => d.ZoneId == zid);

            if (_selectedTypes.Count > 0)
                query = query.Where(d => _selectedTypes.Contains(d.Type ?? string.Empty));

            query = _powerFilter switch
            {
                PowerFilterOn => query.Where(d => d.Power),
                PowerFilterOff => query.Where(d => !d.Power),
                _ => query
            };

            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim();
                query = query.Where(d =>
                    (!string.IsNullOrWhiteSpace(d.Name) && d.Name.Contains(s, StringComparison.OrdinalIgnoreCase))
                    || (!string.IsNullOrWhiteSpace(d.Type) && d.Type.Contains(s, StringComparison.OrdinalIgnoreCase))
                    || (!string.IsNullOrWhiteSpace(d.ZoneName) && d.ZoneName.Contains(s, StringComparison.OrdinalIgnoreCase)));
            }

            return query;
        }
    }

    private async Task OpenAddZoneDialogAsync()
    {
        if (!_isAdmin)
            return;

        var dialog = await Dialog.ShowAsync<AddZoneDialog>("Add zone",
            options: new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });

        var result = await dialog.Result;
        if (result is null || result.Canceled)
            return;

        if (result.Data is int newZoneId)
        {
            await ReloadAsync();
            _selectedZoneId = newZoneId;
        }
        else
        {
            await ReloadAsync();
        }
    }

    private async Task OpenManageZonesDialogAsync()
    {
        if (!_isAdmin)
            return;

        var dialog = await Dialog.ShowAsync<ManageZonesDialog>("Manage zones",
            options: new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;
        if (result is null || result.Canceled)
            return;

        await ReloadAsync();
    }

    private async Task OpenAddDeviceDialogAsync()
    {
        if (!_isAdmin && !_access.CanOperateAny)
            return;

        var parameters = new DialogParameters
        {
            [nameof(AddDeviceDialog.DefaultZoneId)] = _selectedZoneId
        };

        var dialog = await Dialog.ShowAsync<AddDeviceDialog>("Add device", parameters,
            new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;
        if (result is null || result.Canceled)
            return;

        await ReloadAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        await _dbLock.WaitAsync();
        try
        {
            _access = await AccessService.GetAccessInfoAsync();
            _isAdmin = _access.IsAdmin;

            _zones.Clear();
            _devices.Clear();
            _deviceTypes.Clear();

            List<int> zoneIds;

            if (_isAdmin)
            {
                var zones = await Db.Zones
                    .AsNoTracking()
                    .OrderBy(z => z.Name)
                    .ToListAsync();

                _zones.AddRange(zones);
                zoneIds = zones.Select(z => z.Id).ToList();
            }
            else
            {
                var accessibleIds = _access.AccessibleZoneIds;
                if (accessibleIds.Count > 0)
                {
                    var zones = await Db.Zones
                        .AsNoTracking()
                        .Where(z => accessibleIds.Contains(z.Id))
                        .OrderBy(z => z.Name)
                        .ToListAsync();

                    _zones.AddRange(zones);
                }
                zoneIds = _zones.Select(z => z.Id).ToList();
            }

            if (zoneIds.Count > 0)
            {
                var devices = await Db.Devices
                    .AsNoTracking()
                    .Include(d => d.Zone)
                    .Include(d => d.DeviceType)
                    .Where(d => zoneIds.Contains(d.ZoneId))
                    .OrderBy(d => d.Zone.Name)
                    .ThenBy(d => d.Name)
                    .ToListAsync();

                foreach (var d in devices)
                {
                    _devices.Add(new DeviceRow
                    {
                        Id = d.Id,
                        ZoneId = d.ZoneId,
                        ZoneName = d.Zone?.Name ?? string.Empty,
                        Name = d.Name,
                        Type = d.DeviceType?.Name ?? string.Empty,
                        IpAddress = d.IpAddress,
                        Power = d.Power,
                        Level = d.Level,
                        CanOperate = _access.CanOperateZone(d.ZoneId)
                    });
                }

                _deviceTypes.AddRange(
                    _devices
                        .Select(d => d.Type)
                        .Where(t => !string.IsNullOrWhiteSpace(t))
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .OrderBy(t => t, StringComparer.OrdinalIgnoreCase));
            }

            if (_selectedZoneId is int sel && zoneIds.Count > 0 && !zoneIds.Contains(sel))
                _selectedZoneId = null;

            _selectedTypes.RemoveWhere(t => !_deviceTypes.Contains(t, StringComparer.OrdinalIgnoreCase));
        }
        finally
        {
            _dbLock.Release();
            _loading = false;
        }
    }

    private void OnSelectedTypesChanged(IEnumerable<string> values)
    {
        _selectedTypes = values
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private bool CanOperateZone(int zoneId)
        => _access.CanOperateZone(zoneId);

    private async Task TogglePowerAsync(DeviceRow row, bool value)
    {
        if (!row.CanOperate)
            return;

        await _dbLock.WaitAsync();
        try
        {
            var zoneId = await Db.Devices
                .AsNoTracking()
                .Where(d => d.Id == row.Id)
                .Select(d => (int?)d.ZoneId)
                .FirstOrDefaultAsync();

            if (zoneId is null)
                return;

            if (!CanOperateZone(zoneId.Value))
            {
                Snackbar.Add("You don't have permission to modify this device.", Severity.Warning);
                return;
            }

            var affected = await Db.Devices
                .Where(d => d.Id == row.Id)
                .ExecuteUpdateAsync(setters => setters.SetProperty(d => d.Power, value));

            if (affected == 1)
                row.Power = value;
            else
                Snackbar.Add("Failed to update power state.", Severity.Error);
        }
        catch
        {
            Snackbar.Add("Error updating power state.", Severity.Error);
        }
        finally
        {
            _dbLock.Release();
        }
    }

    private async Task UpdateLevelAsync(DeviceRow row, int value)
    {
        if (!row.CanOperate)
            return;

        await _dbLock.WaitAsync();
        try
        {
            var zoneId = await Db.Devices
                .AsNoTracking()
                .Where(d => d.Id == row.Id)
                .Select(d => (int?)d.ZoneId)
                .FirstOrDefaultAsync();

            if (zoneId is null)
                return;

            if (!CanOperateZone(zoneId.Value))
            {
                Snackbar.Add("You don't have permission to modify this device.", Severity.Warning);
                return;
            }

            var affected = await Db.Devices
                .Where(d => d.Id == row.Id)
                .ExecuteUpdateAsync(setters => setters.SetProperty(d => d.Level, value));

            if (affected == 1)
                row.Level = value;
            else
                Snackbar.Add("Failed to update level.", Severity.Error);
        }
        catch
        {
            Snackbar.Add("Error updating level.", Severity.Error);
        }
        finally
        {
            _dbLock.Release();
        }
    }

    private async Task ChangeDeviceZoneAsync(DeviceRow row, int newZoneId)
    {
        if (!_isAdmin)
            return;

        if (row.ZoneId == newZoneId)
            return;

        if (_zones.All(z => z.Id != newZoneId))
        {
            Snackbar.Add("Invalid zone.", Severity.Warning);
            return;
        }

        var reload = false;
        await _dbLock.WaitAsync();
        try
        {
            var affected = await Db.Devices
                .Where(d => d.Id == row.Id)
                .ExecuteUpdateAsync(setters => setters.SetProperty(d => d.ZoneId, newZoneId));

            reload = affected == 1;
        }
        catch
        {
            Snackbar.Add("Error changing device zone.", Severity.Error);
        }
        finally
        {
            _dbLock.Release();
        }

        if (reload)
            await ReloadAsync();
    }

    private sealed class DeviceRow
    {
        public int Id { get; set; }
        public int ZoneId { get; set; }
        public string ZoneName { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string? IpAddress { get; set; }
        public bool Power { get; set; }
        public int Level { get; set; }
        public bool CanOperate { get; set; }
    }
}
