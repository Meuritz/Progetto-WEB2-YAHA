@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Progetto_Web_2_IoT_Auth.Data
@using Progetto_Web_2_IoT_Auth.Data.Model

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">New zone</MudText>

            <MudTextField @bind-Value="_name" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Name is required" />

            <MudSelect T="string" Label="Type" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="_type">
                <MudSelectItem Value="@ZoneTypeIndoor">indoor</MudSelectItem>
                <MudSelectItem Value="@ZoneTypeOutdoor">outdoor</MudSelectItem>
            </MudSelect>
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="_saving">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_saving">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Inject] private DbContextSQLite Db { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private const string ZoneTypeIndoor = "indoor";
    private const string ZoneTypeOutdoor = "outdoor";

    private string _name = string.Empty;
    private string _type = ZoneTypeIndoor;
    private bool _saving;

    private async Task SaveAsync()
    {
        if (_saving)
            return;

        _saving = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (!authState.User.IsInRole("admin"))
            {
                Snackbar.Add("This operation is restricted to administrators.", Severity.Warning);
                MudDialog.Cancel();
                return;
            }

            var name = (_name ?? string.Empty).Trim();
            var type = (_type ?? string.Empty).Trim();

            if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(type))
                return;

            type = type.ToLowerInvariant();
            if (type is not (ZoneTypeIndoor or ZoneTypeOutdoor))
            {
                Snackbar.Add("Invalid type: choose 'indoor' or 'outdoor'.", Severity.Warning);
                return;
            }

            var exists = await Db.Zones
                .AsNoTracking()
                .AnyAsync(z => z.Name == name);

            if (exists)
            {
                Snackbar.Add("A zone with this name already exists.", Severity.Warning);
                return;
            }

            var zone = new Zone
            {
                Name = name,
                Type = type
            };

            Db.Zones.Add(zone);
            await Db.SaveChangesAsync();

            Snackbar.Add($"Zone '{zone.Name}' created.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(zone.Id));
        }
        catch
        {
            Snackbar.Add("Error creating zone.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
