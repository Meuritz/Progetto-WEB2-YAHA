@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Progetto_Web_2_IoT_Auth.Data
@using Progetto_Web_2_IoT_Auth.Data.Model
@using Progetto_Web_2_IoT_Auth.Components.Pages.Devices.Dialogs
@using Progetto_Web_2_IoT_Auth.Services
@using System.Net

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">New device</MudText>

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else
            {
                @if (_zones.Count == 0)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                        No zones available.
                    </MudAlert>
                }

                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudSelect T="int?" Label="Zone" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="_zoneId" Style="flex:1" Disabled="@(_zones.Count == 0)">
                        @foreach (var z in _zones)
                        {
                            <MudSelectItem T="int?" Value="@((int?)z.Id)">@z.Name</MudSelectItem>
                        }
                    </MudSelect>

                    @if (_isAdmin)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Disabled="_saving" OnClick="OpenAddZoneDialogAsync" />
                    }
                </MudStack>

                <MudTextField @bind-Value="_name" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Name is required" />

                <MudTextField @bind-Value="_ipAddress" Label="IP" Variant="Variant.Outlined" Margin="Margin.Dense" />

                @if (_types.Count == 0)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                        No device types configured.
                    </MudAlert>
                }

                <MudSelect T="int?" Label="Type" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="_typeId" Required="true" RequiredError="Type is required" Disabled="@(_types.Count == 0)">
                    @foreach (var t in _types)
                    {
                        <MudSelectItem T="int?" Value="@((int?)t.Id)">@t.Name</MudSelectItem>
                    }
                </MudSelect>
            }
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="_saving">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@(_saving || _loading || _zones.Count == 0 || _types.Count == 0)">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public int? DefaultZoneId { get; set; }

    [Inject] private DbContextSQLite Db { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] private UserAccessService AccessService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private IDialogService Dialog { get; set; } = null!;

    private readonly List<Zone> _zones = new();
    private readonly List<DeviceType> _types = new();
    private UserAccessInfo _access = null!;
    private bool _isAdmin;

    private bool _loading;
    private bool _saving;

    private int? _zoneId;
    private string _name = string.Empty;
    private string _ipAddress = string.Empty;
    private int? _typeId;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _access = await AccessService.GetAccessInfoAsync();
            _isAdmin = _access.IsAdmin;

            if (!_isAdmin && !_access.CanOperateAny)
            {
                Snackbar.Add("You don't have permission to add devices.", Severity.Warning);
                MudDialog.Cancel();
                return;
            }

            List<Zone> zones;
            if (_isAdmin)
            {
                zones = await Db.Zones
                    .AsNoTracking()
                    .OrderBy(z => z.Name)
                    .ToListAsync();
            }
            else
            {
                var operatorZoneIds = _access.OperatorZoneIds;
                zones = await Db.Zones
                    .AsNoTracking()
                    .Where(z => operatorZoneIds.Contains(z.Id))
                    .OrderBy(z => z.Name)
                    .ToListAsync();
            }

            var types = await Db.DeviceTypes
                .AsNoTracking()
                .OrderBy(t => t.Name)
                .ToListAsync();

            _zones.Clear();
            _zones.AddRange(zones);

            _types.Clear();
            _types.AddRange(types);

            if (_zones.Count > 0)
            {
                if (DefaultZoneId is int zid && _zones.Any(z => z.Id == zid))
                    _zoneId = zid;
                else
                    _zoneId = _zones[0].Id;
            }

            if (_types.Count > 0)
                _typeId = _types[0].Id;
        }
        catch
        {
            Snackbar.Add("Error loading zones.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenAddZoneDialogAsync()
    {
        var dialog = await Dialog.ShowAsync<AddZoneDialog>("Add zone",
            options: new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });

        var result = await dialog.Result;
        if (result is null || result.Canceled)
            return;

        var zones = await Db.Zones
            .AsNoTracking()
            .OrderBy(z => z.Name)
            .ToListAsync();

        _zones.Clear();
        _zones.AddRange(zones);

        if (result.Data is int newZoneId && _zones.Any(z => z.Id == newZoneId))
            _zoneId = newZoneId;
        else if (_zoneId is null && _zones.Count > 0)
            _zoneId = _zones[0].Id;
    }

    private async Task SaveAsync()
    {
        if (_saving || _loading)
            return;

        _saving = true;
        try
        {
            if (_zoneId is not int zid)
                return;

            if (!_access.IsAdmin && !_access.CanOperateZone(zid))
            {
                Snackbar.Add("You don't have permission to add devices to this zone.", Severity.Warning);
                return;
            }

            if (_typeId is not int typeId)
                return;

            var name = (_name ?? string.Empty).Trim();
            var ip = (_ipAddress ?? string.Empty).Trim();

            if (string.IsNullOrWhiteSpace(name))
                return;

            if (!string.IsNullOrWhiteSpace(ip) && !IPAddress.TryParse(ip, out _))
            {
                Snackbar.Add("Invalid IP address.", Severity.Warning);
                return;
            }

            if (!_types.Any(t => t.Id == typeId))
                return;

            var device = new Device
            {
                ZoneId = zid,
                Name = name,
                IpAddress = string.IsNullOrWhiteSpace(ip) ? null : ip,
                DeviceTypeId = typeId,
            };

            Db.Devices.Add(device);
            await Db.SaveChangesAsync();

            Snackbar.Add($"Device '{device.Name}' created.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(device.Id));
        }
        catch
        {
            Snackbar.Add("Error creating device.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
