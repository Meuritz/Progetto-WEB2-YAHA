@page "/settings"
@using Microsoft.AspNetCore.Authorization
@using Progetto_Web_2_IoT_Auth.Services
@using MudBlazor
@attribute [Authorize(Roles = "admin")]
@inject SettingsService SettingsService
@inject ISnackbar Snackbar

<PageTitle>App Settings</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Application Settings</MudText>

<MudCard>
    <MudCardContent>
        <MudTextField @bind-Value="CitySetting" Label="Reference city (for Weather)"
                      Variant="Variant.Outlined" Class="mb-4" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings">Save</MudButton>
    </MudCardContent>
</MudCard>

@code {
    private string CitySetting { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        CitySetting = await SettingsService.GetSettingAsync("WeatherCity", "Roma");
    }

    private async Task SaveSettings()
    {
        if (!string.IsNullOrWhiteSpace(CitySetting))
        {
            await SettingsService.SetSettingAsync("WeatherCity", CitySetting.Trim());
            Snackbar.Add("Settings saved successfully.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Please enter a valid city name.", Severity.Warning);
        }
    }
}
