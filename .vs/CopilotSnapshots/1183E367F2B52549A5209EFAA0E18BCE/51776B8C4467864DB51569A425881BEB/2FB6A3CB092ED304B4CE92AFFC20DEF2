using Microsoft.EntityFrameworkCore;
using Progetto_Web_2_IoT_Auth.Data.Model;

namespace Progetto_Web_2_IoT_Auth.Data
{
    public class DbContextSQLite : DbContext
    {
        public DbContextSQLite(DbContextOptions options) : base(options)
        {

        }

        public DbSet<User> User { get; set; }
        public DbSet<UserGroup> UserGroup { get; set; }
        public DbSet<DeviceGroup> DeviceGroup { get; set; }
        public DbSet<Device> Device { get; set; }

        protected override void OnModelCreating(ModelBuilder modelBuilder)
        {
            base.OnModelCreating(modelBuilder);

            // Seed default groups
            modelBuilder.Entity<UserGroup>().HasData(new UserGroup
            {
                Id = 1,
                Name = "dafault"
            });

            modelBuilder.Entity<DeviceGroup>().HasData(new DeviceGroup
            {
                Id = 1,
                Name = "dafault"
            });
        }
    }

}
